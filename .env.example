NODE_ENV=development
PORT=3000

# PostgreSQL on Neon
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Número máximo de conexiones en el pool de pg por instancia.
# Ajustar para no exceder los límites del plan de Neon.
PG_POOL_MAX=20

# Redis (Redis Cloud, Upstash, o local redis://localhost:6379).
# En producción exigir TLS: rediss://
REDIS_URL=redis://default:password@host:port

# --- Better Auth ---
# Secret en código: opción `secret`; nombre recomendado en env: BETTER_AUTH_API_KEY.
# Compat: si existe BETTER_AUTH_SECRET, se usa como valor hasta migrar.
BETTER_AUTH_API_KEY=change-me-to-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# CORS — varios orígenes separados por comas (ej. producción: https://aduvanta.com,https://www.aduvanta.com).
# En producción, `http://` o `localhost` son rechazados por la validación.
CORS_ORIGIN=http://localhost:3001

# Frontend (Stripe, redirects, emails transaccionales)
FRONTEND_URL=http://localhost:3001

# --- Cookies ---
# Opcional: cookies entre subdominios (.tudominio.com)
# COOKIE_DOMAIN=
# Opcional: secret para signed cookies (mínimo 32 chars)
# COOKIE_SECRET=

# --- Google OAuth (opcional) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Stripe (opcional) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=

# --- S3 compatible (opcional — documentos y exportaciones) ---
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Emails transaccionales (Resend) ---
# Si RESEND_API_KEY está vacío, los emails se loguean en lugar de enviarse.
# RESEND_API_KEY=
EMAIL_FROM=Aduvanta <no-reply@aduvanta.com>
# Exige que el usuario verifique su email antes de iniciar sesión.
EMAIL_VERIFICATION_REQUIRED=false

# Cuenta superadmin de plataforma (se usa en drizzle/seeds/system-admin-seed.sql).
# SYSTEM_ADMIN_EMAIL=

# Tamaño máximo permitido para uploads (bytes). Default 25 MB.
# MAX_UPLOAD_SIZE=26214400

# --- Cifrado de integraciones (opcional, 64 hex chars = 32 bytes) ---
# Rotar este valor requiere re-cifrar todos los valores en integrations.secretEncrypted.
# ENCRYPTION_KEY=

# --- Sentry (opcional) ---
# SENTRY_DSN=
