NODE_ENV=development
PORT=3000

# PostgreSQL on Neon
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis (Redis Cloud, Upstash, or local redis://localhost:6379)
REDIS_URL=redis://default:password@host:port

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# CORS — varios orígenes separados por comas (ej. producción: https://aduvanta.com,https://www.aduvanta.com)
CORS_ORIGIN=http://localhost:3001

# Frontend (Stripe, redirects)
FRONTEND_URL=http://localhost:3001

# Opcional: cookies entre subdominios (.tudominio.com)
# COOKIE_DOMAIN=

# Google OAuth (opcional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Stripe (opcional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=

# S3 compatible (opcional — documentos y exportaciones)
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Opcional: integraciones cifradas (hex 64 caracteres)
# ENCRYPTION_KEY=

# Sentry (opcional)
# SENTRY_DSN=
